{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./build",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true
  },
  "include": [
    "src/auth.ts",
    "src/cli.ts",
    "src/config.ts",
    "src/index.ts",
    "src/okta-client.ts"
  ],
  "exclude": ["node_modules", "build"]
}
