# Optional developer override file.
# Normal setup uses: okta-workspace-mcp init

OKTA_ORG_URL=https://your-org.okta.com
OKTA_CLIENT_ID=your-oidc-app-client-id

# Defaults used when omitted:
# OKTA_AUTH_SERVER=default
# OKTA_SCOPES=openid profile email offline_access
# OKTA_MCP_AUTH_ON_START=1

# Optional local session diagnostics collector:
# OKTA_MCP_LAB_EVENT_URL=http://127.0.0.1:8765/v1/lab-events
# OKTA_MCP_LAB_EVIDENCE=proof
