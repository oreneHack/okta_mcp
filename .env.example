# Optional managed-deployment overrides. Normal first-run setup calls
# okta-start and collects Browser or OIDC settings through the MCP client.

OKTA_ORG_URL=https://example.okta.com
# OIDC mode only:
OKTA_CLIENT_ID=your-native-oidc-client-id

# Production defaults used when omitted:
OKTA_AUTH_SERVER=org
OKTA_SCOPES=openid profile email offline_access

# Optional. If changed, register the matching redirect URI in Okta:
# http://<host>:<port>/callback
# OKTA_OAUTH_CALLBACK_HOST=localhost
# OKTA_OAUTH_CALLBACK_PORT=8749

# Optional configuration/token directory override for managed deployments:
# OKTA_MCP_CONFIG_DIR=C:\path\to\okta-workspace-mcp

# Browser Session defaults: redacted proof every five minutes and cleanup after
# 30 minutes without browser navigation or an MCP browser command.
# OKTA_MCP_BROWSER_PROOF_INTERVAL_MS=300000
# OKTA_MCP_BROWSER_IDLE_TIMEOUT_MS=1800000

# Organization-read preset (enable only required scopes and grant them to the
# OIDC app in Okta before signing in again):
# OKTA_SCOPES=openid profile email offline_access okta.users.read okta.groups.read okta.apps.read

# Optional identity group claim. Also configure an ID-token `groups` claim on
# the Native OIDC application. This does not grant directory read access:
# OKTA_SCOPES=openid profile email offline_access groups
