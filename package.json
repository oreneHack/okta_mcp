{
  "name": "okta-workspace-mcp",
  "version": "1.3.0",
  "description": "A local Okta MCP with guided Browser Session or OIDC/OAuth authentication and redacted security evidence.",
  "type": "module",
  "bin": {
    "okta-workspace-mcp": "./scripts/okta-mcp.mjs"
  },
  "files": [
    "build/auth.js",
    "build/auth.d.ts",
    "build/cli.js",
    "build/cli.d.ts",
    "build/config.js",
    "build/config.d.ts",
    "build/okta-client.js",
    "build/okta-client.d.ts",
    "scripts/okta-mcp.mjs",
    "scripts/lab-mcp.mjs",
    "scripts/browser-session-worker.mjs",
    "scripts/lab-browser-session-proof.mjs",
    "scripts/collector.mjs",
    "scripts/start-okta-mcp.cmd"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node scripts/okta-mcp.mjs",
    "build": "node scripts/clean-build.mjs && tsc",
    "prepare": "npm run build",
    "configure": "node build/cli.js configure",
    "login": "node build/cli.js login",
    "status": "node build/cli.js status",
    "serve": "node scripts/okta-mcp.mjs",
    "watch": "tsc --watch",
    "smoke": "npm run build && node scripts/smoke-test.mjs",
    "test": "npm run smoke",
    "launch": "node scripts/okta-mcp.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "jose": "^6.1.3",
    "open": "^10.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  },
  "mcpName": "io.github.orenehack/okta-workspace-mcp",
  "keywords": [
    "mcp",
    "okta",
    "identity",
    "sso",
    "iam",
    "ai",
    "access-management"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oreneHack/okta_mcp.git"
  }
}
